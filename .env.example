# ── Database (Dokku Postgres) ─────────────────────────────────────────────────
DATABASE_URL=postgres://user:password@host:5432/dbname

# ── OpenAI (server-only) ──────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=production
# PORT is set automatically by Dokku — do not set it manually

# ── Optional: first-run seed admin ───────────────────────────────────────────
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=changeme
